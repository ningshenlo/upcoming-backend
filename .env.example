# Database
DATABASE_URL=

# Cloudflare R2 raw archive.
# In production keep REQUIRE_R2_ARCHIVE=1 and use S3 credentials, not Wrangler login state.
R2_BUCKET_NAME=upcoming-games-raw
R2_ACCOUNT_ID=
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_WRANGLER_UPLOAD=0
REQUIRE_R2_ARCHIVE=1

# Local fallback archive path. Used only when R2 is not configured or for temp Wrangler uploads.
RAW_ARCHIVE_DIR=/app/var/raw

# HTTP identity
UPCOMING_GAMES_USER_AGENT=UpcomingGamesBot/0.1 (+https://upcominggames.com)

# Hot tracker
YOUTUBE_API_KEY=
HOT_TRACKER_CHANNELS=youtube
HOT_TRACKER_ENABLED=1
HOT_TRACKER_INTERVAL_MINUTES=360
HOT_TRACKER_DISCOVERY_LIMIT=2000
HOT_TRACKER_REFRESH_LIMIT=5000
HOT_TRACKER_REDISCOVERY_DAYS=7
DFS=
DATAFORSEO_API_KEY=
DATAFORSEO_PINGBACK_URL=
DATAFORSEO_YOUTUBE_LOCATION_CODE=2840
DATAFORSEO_YOUTUBE_LANGUAGE_CODE=en
DATAFORSEO_YOUTUBE_BLOCK_DEPTH=10
DATAFORSEO_YOUTUBE_TASK_GET_ENABLED=1
DATAFORSEO_YOUTUBE_TASK_GET_INTERVAL_MINUTES=5
DATAFORSEO_YOUTUBE_TASK_GET_LIMIT=50

# Official release sync command defaults
OFFICIAL_RELEASE_SYNC_ENABLED=1
OFFICIAL_RELEASE_SYNC_INTERVAL_MINUTES=720
OFFICIAL_RELEASE_COLLECTORS=steam,nintendo,playstation,xbox,epic,gog
OFFICIAL_RELEASE_LIMIT=50

# IGDB discovery
IGDB_DISCOVERY_SYNC_ENABLED=1
IGDB_DISCOVERY_SYNC_INTERVAL_MINUTES=1440
IGDB_CLIENT_ID=
IGDB_ACCESS_TOKEN=
IGDB_DISCOVERY_LIMIT=50

# Steam metadata backfill
STEAM_METADATA_BACKFILL_LIMIT=80
SCHEDULER_TICK_SECONDS=60
SCHEDULER_JOB_TIMEOUT_MINUTES=120
STEAM_TRACKED_REFRESH_ENABLED=1
STEAM_TRACKED_REFRESH_INTERVAL_MINUTES=360
STEAM_TRACKED_REFRESH_LIMIT=80
PLAYSTATION_TRACKED_REFRESH_ENABLED=1
PLAYSTATION_TRACKED_REFRESH_INTERVAL_MINUTES=360
PLAYSTATION_TRACKED_REFRESH_LIMIT=80
NINTENDO_TRACKED_REFRESH_ENABLED=1
NINTENDO_TRACKED_REFRESH_INTERVAL_MINUTES=360
NINTENDO_TRACKED_REFRESH_LIMIT=80
XBOX_TRACKED_REFRESH_ENABLED=1
XBOX_TRACKED_REFRESH_INTERVAL_MINUTES=360
XBOX_TRACKED_REFRESH_LIMIT=80
EPIC_TRACKED_REFRESH_ENABLED=1
EPIC_TRACKED_REFRESH_INTERVAL_MINUTES=360
EPIC_TRACKED_REFRESH_LIMIT=80
GOG_TRACKED_REFRESH_ENABLED=1
GOG_TRACKED_REFRESH_INTERVAL_MINUTES=360
GOG_TRACKED_REFRESH_LIMIT=80
STEAM_APPDETAILS_ENABLED=1
STEAM_APP_PAGE_TAGS_ENABLED=1
